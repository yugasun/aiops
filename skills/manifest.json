{
  "manifestVersion": 3,
  "version": "1.4.0",
  "tier1": [
    { "name": "aiops", "personal": true, "role": "router" },
    { "name": "aiops-implement", "personal": true, "role": "delivery" },
    { "name": "aiops-setup", "personal": true, "role": "setup" },
    { "name": "explore", "personal": false, "role": "alignment" },
    { "name": "lean", "personal": false, "role": "discipline", "alwaysOn": true },
    { "name": "file-refactor", "personal": false, "role": "discipline" },
    { "name": "prune", "personal": false, "role": "delivery-gate" },
    { "name": "grill-with-docs", "personal": false, "role": "alignment" },
    { "name": "grilling", "personal": false, "role": "alignment" },
    { "name": "domain-modeling", "personal": false, "role": "alignment" },
    { "name": "tdd", "personal": false, "role": "delivery-gate" },
    { "name": "diagnosing-bugs", "personal": false, "role": "bug" },
    { "name": "triage", "personal": false, "role": "incoming" },
    { "name": "to-prd", "personal": false, "role": "planning" },
    { "name": "to-issues", "personal": false, "role": "planning" },
    { "name": "handoff", "personal": false, "role": "cross-session" },
    { "name": "prototype", "personal": false, "role": "prototype" },
    { "name": "review", "personal": false, "role": "delivery-gate" },
    { "name": "gitops", "personal": true, "role": "delivery" },
    { "name": "ui-mockup", "personal": false, "role": "design" },
    { "name": "improve-codebase-architecture", "personal": false, "role": "architecture-health" },
    { "name": "architect-design", "personal": false, "role": "alignment" },
    { "name": "code-graph", "personal": false, "role": "infrastructure" }
  ],
  "tier2Deferred": [
    { "name": "codebase-design" },
    { "name": "writing-great-skills" },
    { "name": "teach" }
  ],
  "agents": [
    {
      "name": "architect",
      "skills": ["explore", "grilling", "grill-with-docs", "domain-modeling", "architect-design", "improve-codebase-architecture", "code-graph"],
      "role": "alignment",
      "outputs": [".scratch/<feature>/NOTES.md", ".scratch/<feature>/tech-spec.md"]
    },
    {
      "name": "design-reviewer",
      "skills": ["review"],
      "role": "design-gate",
      "outputs": [".scratch/<feature>/DESIGN_REVIEW.md"]
    },
    {
      "name": "planner",
      "skills": ["to-prd", "to-issues", "handoff", "aiops-setup"],
      "role": "planning",
      "outputs": [".scratch/<feature>/PRD.md", ".scratch/<feature>/plan.md", ".scratch/<feature>/issues/"]
    },
    {
      "name": "prototyper",
      "skills": ["prototype", "lean"],
      "role": "prototype",
      "outputs": [".scratch/<feature>/prototype/", ".scratch/<feature>/VERDICT.md"]
    },
    {
      "name": "builder",
      "skills": ["aiops-implement", "tdd", "lean"],
      "role": "delivery",
      "outputs": ["source code", "test files"]
    },
    {
      "name": "ui-designer",
      "skills": ["ui-mockup"],
      "role": "design",
      "outputs": [".scratch/<feature>/mockups/", ".scratch/<feature>/mockups/design-notes.md"]
    },
    {
      "name": "code-reviewer",
      "skills": ["review"],
      "role": "delivery-gate",
      "outputs": [".scratch/<feature>/REVIEW.md"]
    },
    {
      "name": "quality-auditor",
      "skills": ["prune"],
      "role": "delivery-gate",
      "outputs": ["prune findings"]
    },
    {
      "name": "gitops",
      "skills": ["gitops"],
      "role": "delivery",
      "outputs": ["git commit", "push confirmation"]
    }
  ]
}
