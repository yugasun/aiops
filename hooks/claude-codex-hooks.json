{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/aiops-activate.js\" 2>/dev/null; exit 0",
            "timeout": 5000,
            "statusMessage": "Loading aiops lean discipline…"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/aiops-graph.js\" 2>/dev/null; exit 0",
            "timeout": 3000,
            "statusMessage": "Checking code graph freshness…"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/aiops-subagent.js\" 2>/dev/null; exit 0",
            "timeout": 3000,
            "statusMessage": "Injecting aiops context for subagent…"
          }
        ]
      }
    ]
  }
}
